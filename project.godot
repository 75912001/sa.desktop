; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="sa.desktop"
run/main_scene="uid://bq4wq8j4y0gk1"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 0)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

YAML="*uid://ihqfb76y0nfd"
GPB="*res://proto/sa.pb.gd"
GPetCalculator="*res://scripts/common/pet.attribute.calculator.gd"
GCfgMgr="*res://scripts/config/manager.gd"
GTrayConfig="*res://scripts/tray/config.gd"
GRecord="*res://scripts/record/record.gd"
GCombatFormation="*res://scripts/combat/combat.formation.gd"
GMainWindowGuideDrawer="*res://scripts/scene.main.window.guides.gd"
GMainWindow="*res://scripts/main.window.global.gd"
GTray="*res://scripts/tray/tray.gd"

[display]

window/size/viewport_width=800
window/size/viewport_height=600
window/size/resizable=false
window/size/borderless=true
window/size/transparent=true
window/size/window_width_override=800
window/size/window_height_override=600
window/per_pixel_transparency/allowed=true
window/per_pixel_transparency/enabled=true

[editor_plugins]

enabled=PackedStringArray("res://addons/miniyaml/plugin.cfg", "res://addons/godobuf/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
environment/defaults/default_clear_color=Color(0, 0, 0, 0)
viewport/transparent_background=true
